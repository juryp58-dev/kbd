<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KBD Scooters — Продажа, Прокат, Сервис в Кипре</title>
    <meta name="description" content="KBD Scooters — Продажа, прокат и сервисный центр электроскутеров на Кипре.">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Oswald:wght@500;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --red: #e50914;
            --red-hover: #ff2b2b;
            --black: #0a0a0a;
            --dark: #121212;
            --gray: #1f1f1f;
            --text-light: #ffffff;
            --text-muted: #a0a0a5;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
            scroll-behavior: smooth;
        }

        body {
            background-color: var(--black);
            color: var(--text-light);
            line-height: 1.6;
        }

        /* Шапка сайта */
        header {
            background-color: rgba(10, 10, 10, 0.95);
            padding: 15px 5%;
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo-container {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .logo-img {
            height: 50px;
            width: auto;
            border-radius: 50%;
        }

        .logo-text {
            font-family: 'Oswald', sans-serif;
            font-size: 24px;
            font-weight: 700;
            letter-spacing: 1px;
        }

        .logo-text span {
            color: var(--red);
        }

        nav a {
            color: var(--text-light);
            text-decoration: none;
            margin-left: 20px;
            font-weight: 600;
            font-size: 15px;
            transition: color 0.2s;
        }

        nav a:hover {
            color: var(--red);
        }

        /* Баннер */
        .hero {
            margin-top: 80px;
            padding: 30px 5% 10px;
            display: flex;
            justify-content: center;
        }

        .hero-container {
            width: 100%;
            max-width: 800px;
            text-align: center;
        }

        .hero-banner-img {
            width: 100%;
            height: auto;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(229, 9, 20, 0.15);
        }

        /* Заголовки */
        .section-title {
            font-family: 'Oswald', sans-serif;
            font-size: 36px;
            text-align: center;
            margin: 50px 0 30px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .section-title span {
            color: var(--red);
        }

        /* Сетка Услуг: Продажа, Прокат, Сервис */
        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            padding: 0 5%;
            max-width: 1200px;
            margin: 0 auto 50px;
        }

        .service-card {
            background-color: var(--gray);
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.05);
            display: flex;
            flex-direction: column;
            transition: transform 0.3s, border-color 0.3s;
        }

        .service-card:hover {
            transform: translateY(-5px);
            border-color: rgba(229, 9, 20, 0.4);
        }

        .service-img-placeholder {
            width: 100%;
            height: 260px;
            background-color: #fff;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 15px;
        }

        .service-img-placeholder img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }

        .service-info {
            padding: 25px;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .service-name {
            font-family: 'Oswald', sans-serif;
            font-size: 24px;
            margin-bottom: 12px;
            text-transform: uppercase;
        }

        .service-desc {
            color: var(--text-muted);
            font-size: 14px;
            margin-bottom: 20px;
        }

        /* Кнопки */
        .btn-action {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background-color: var(--red);
            color: white;
            text-decoration: none;
            padding: 12px 20px;
            border-radius: 8px;
            font-weight: 700;
            transition: background-color 0.2s;
            gap: 10px;
            text-transform: uppercase;
            font-size: 13px;
        }

        .btn-action:hover {
            background-color: var(--red-hover);
        }

        .btn-center-container {
            text-align: center;
            margin-bottom: 60px;
        }

        .btn-secondary {
            background-color: transparent;
            border: 2px solid var(--text-light);
            color: var(--text-light);
            cursor: pointer;
            padding: 12px 30px;
            border-radius: 8px;
            font-weight: 700;
            text-transform: uppercase;
            transition: all 0.3s;
        }

        .btn-secondary:hover {
            background-color: var(--text-light);
            color: var(--black);
        }

        /* Блок отзывов */
        .reviews-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 0 5%;
        }

        .review-card {
            background-color: var(--gray);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 20px;
            border-left: 4px solid var(--red);
        }

        .review-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
            font-weight: 600;
        }

        .review-stars {
            color: #ffcc00;
        }

        /* Скрытые отзывы */
        .hidden-reviews {
            display: none;
        }

        .hidden-reviews.show {
            display: block;
        }

        footer {
            background-color: #050505;
            padding: 30px 5%;
            text-align: center;
            color: var(--text-muted);
            font-size: 14px;
            margin-top: 50px;
            border-top: 1px solid rgba(255,255,255,0.05);
        }

        .whatsapp-icon {
            width: 16px;
            height: 16px;
            fill: currentColor;
        }

        @media (max-width: 768px) {
            header { padding: 15px 3%; }
            nav a { margin-left: 10px; font-size: 13px; }
            .section-title { font-size: 28px; }
        }
    </style>
</head>
